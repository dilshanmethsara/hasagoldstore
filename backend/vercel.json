{
  "version": 2,
  "buildCommand": "npm run prisma:generate",
  "outputDirectory": ".",
  "installCommand": "npm install --include=dev",
  "functions": {
    "api/index.ts": {
      "memory": 256,
      "maxDuration": 10
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/api/index.ts"
    }
  ]
}
